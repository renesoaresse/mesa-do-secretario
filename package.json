{
  "name": "mesadoscretario",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Renê Rocha Soares Neto"
  },
  "contributors": [
    {
      "name": "Marcio Alves de Andrade"
    }
  ],
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist dist-electron release",
    "electron:tsc": "tsc -p src/electron/tsconfig.json",
    "build:web": "vite build",
    "build:electron": "yarn electron:tsc",
    "build": "yarn clean && yarn build:web && yarn build:electron",
    "electron:dev": "concurrently -k --names \"vite,electron\" --prefix \"[{name}]\" \"vite\" \"wait-on http://localhost:5173 && yarn electron:tsc && electron .\"",
    "dist": "electron-builder --win --publish never && electron-builder --mac --publish never",
    "dist:win": "yarn build && electron-builder --win --publish never",
    "dist:mac": "yarn build && electron-builder --mac --publish never",
    "prepare": "husky",
    "lint": "eslint src/ --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron-forge/cli": "^7.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.glmese.mesadosecretario",
    "productName": "Mesa do Secretario",
    "publish": [],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "executableName": "mesa-do-secretario",
      "artifactName": "mesa-do-secretario-setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mesa do Secretario"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "artifactName": "mesa-do-secretario-${version}.${ext}",
      "category": "public.app-category.productivity",
      "identity": null
    }
  }
}
